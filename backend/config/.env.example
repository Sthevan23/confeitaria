# Copie para .env e ajuste os valores (não versione o .env)

DB_DRIVER=json
# Quando migrar para MySQL na Hostinger:
# DB_DRIVER=mysql
# DB_HOST=localhost
# DB_NAME=uXXXX_gimarry
# DB_USER=uXXXX_user
# DB_PASS=senha_forte

# Caminho do JSON (padrão: backend/storage/data.json)
# DATA_FILE=

APP_URL=https://gimarrybolos.com.br
CORS_ORIGIN=https://gimarrybolos.com.br

# Em desenvolvimento local (Live Server + API):
# CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500
